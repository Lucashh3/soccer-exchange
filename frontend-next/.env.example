# ── Backend Express ────────────────────────────────────────────────────────────
# URL do servidor Node (usada pelas rotas API do Next.js no servidor)
# Em produção: https://api.seu-dominio.com
API_URL=http://localhost:3001

# API key para autenticar no backend (deve ser igual ao API_KEY do backend)
# Deixar vazio se o backend não exigir autenticação
INTERNAL_API_KEY=
