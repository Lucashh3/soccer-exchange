# ── LLM APIs ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ── Servidor Express (backend) ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# API key para proteger os endpoints (deixar vazio desativa a autenticação)
API_KEY=

# Origens permitidas no CORS (domínio do frontend em produção)
ALLOWED_ORIGIN=http://localhost:3000

# ── Banco de dados ─────────────────────────────────────────────────────────────
DB_PATH=./data/soccer.db

# ── Scraper Python (scraper-service) ──────────────────────────────────────────
SCRAPER_URL=http://localhost:8001

# ── ML / Fine-tuning ───────────────────────────────────────────────────────────
# Caminho do executável Python para o cron de fine-tuning
# Em produção com venv: ml/venv/bin/python3
PYTHON_PATH=python3

# ── Scraping ───────────────────────────────────────────────────────────────────
SCRAPING_DELAY_MS=1500
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
